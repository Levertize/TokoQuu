# Server Config
PORT=3001
NODE_ENV=development

# Database Config
DB_PATH=./database.db

# JWT Config
JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_random_di_production
JWT_EXPIRES_IN=7d

# AI Provider: 'gemini' atau 'ollama'
AI_PROVIDER=gemini

# Gemini API Key (Required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Ollama Config (Required if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Store Config
STORE_NAME=Toko Maju Jaya
